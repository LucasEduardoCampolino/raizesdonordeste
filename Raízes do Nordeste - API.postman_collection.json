      "item": [
        {
          "name": "Criar Usuário (Com LGPD)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"nome\": \"Lucas Campolino\",\n    \"email\": \"lucas@teste.com\",\n    \"senha\": \"senha123\",\n    \"aceitouLgpd\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/usuarios",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["usuarios"]
            }
          }
        },
        {
          "name": "Login (Gerar Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Salva o token automaticamente em uma variável global\nif(pm.response.code === 200) {\n    pm.globals.set(\"token\", pm.response.text());\n}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"lucas@teste.com\",\n    \"senha\": \"senha123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8080/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
